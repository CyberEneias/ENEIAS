-- Função instakill
local function doInstaKill()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local targets = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Parent ~= char and obj.Health > 0 then
            local targetRoot = obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent:FindFirstChild("Torso") or obj.Parent:FindFirstChild("UpperTorso")
            if targetRoot and (targetRoot.Position - root.Position).Magnitude <= instakillRadius then
                table.insert(targets, obj)
            end
        end
    end
    
    for _, hum in ipairs(targets) do
        if hum and hum.Parent and hum.Health > 0 then
            hum.Health = 0
            task.wait(instakillDelay)
        end
    end
end

