-- ===================== FEATURE: AUTOFARM =====================
local lockedNPC = nil

local function autofarmLoop()
    if not state.autofarmEnabled then return end
    local root = getCharComponents()
    if not root then return end

    if not isValidNPC(lockedNPC) then
        lockedNPC = findClosestNPC()
    end

    local npc = lockedNPC
    if not npc then return end

    local npcRoot = npc:FindFirstChild("HumanoidRootPart")
    if not npcRoot then
        lockedNPC = nil
        return
    end

    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    if state.autofarmMode == "Above" then
        local targetPos = npcRoot.Position + Vector3.new(0, state.autofarmDistance, 0)
        root.CFrame = CFrame.new(targetPos) * CFrame.Angles(math.rad(-90), 0, 0)
    else
        local backVec = -npcRoot.CFrame.LookVector * state.autofarmDistance
        local upVec = Vector3.new(0, CONFIG.HEIGHT_OFFSET, 0)
        local targetPos = npcRoot.Position + backVec + upVec
        root.CFrame = CFrame.new(targetPos, npcRoot.Position)
    end
end

-- ===================== FEATURE: LOCK ON =====================
local lockedTarget = nil

local function lockOnLoop()
    if not state.lockOnEnabled then return end
    local camera = workspace.CurrentCamera
    local target = lockedTarget

    if state.autofarmEnabled and lockedNPC then
        target = lockedNPC
    end

    if not target or not target.Parent then
        target = findClosestNPC()
        lockedTarget = target
    end

    if target then
        local npcRoot = target:FindFirstChild("HumanoidRootPart")
        if npcRoot then
            camera.CFrame = CFrame.new(camera.CFrame.Position, npcRoot.Position)
        end
    end
end

-- ===================== FEATURE: KILL AURA =====================
local lastM1Click = 0

local function m1MacroLoop()
    if not state.m1MacroEnabled then return end
    local root = getCharComponents()
    if not root then return end
    local now = tick()
    if now - lastM1Click >= state.m1ClickDelay then
        lastM1Click = now
        for _, npc in ipairs(LivingFolder:GetChildren()) do
            if npc:IsA("Model") and npc ~= LocalPlayer.Character then
                local hum = npc:FindFirstChild("Humanoid")
                local npcRoot = npc:FindFirstChild("HumanoidRootPart")
                if hum and npcRoot and hum.Health > 0 then
                    local dist = (root.Position - npcRoot.Position).Magnitude
                    if dist <= state.killAuraRange then
                        pcall(function() hum:TakeDamage(hum.MaxHealth) end)
                    end
                end
            end
        end
    end
end

-- ===================== FEATURE: INSTAKILL =====================
local function instakillLoop()
    if not state.instakillEnabled then return end
    local root = getCharComponents()
    if not root then return end
    for _, npc in ipairs(LivingFolder:GetChildren()) do
        if npc:IsA("Model") and npc ~= LocalPlayer.Character then
            local hum = npc:FindFirstChild("Humanoid")
            local npcRoot = npc:FindFirstChild("HumanoidRootPart")
            if hum and npcRoot and hum.Health > 0 then
                local dist = (root.Position - npcRoot.Position).Magnitude
                if dist <= state.instakillRadius then
                    pcall(function() hum.Health = 0 end)
                end
            end
        end
    end
end

-- ===================== TELEPORT SYSTEM =====================
local function ultraSmoothTeleport(targetPosition)
    if state.isTeleporting then return false end
    local root = getCharComponents()
    if not root then return false end

    state.isTeleporting = true
    local startPos = root.Position
    local distance = (targetPosition - startPos).Magnitude

    if distance < 10 then
        root.CFrame = CFrame.new(targetPosition)
        state.isTeleporting = false
        return true
    end

    if distance > CONFIG.MAX_TELEPORT_DISTANCE then
        local direction = (targetPosition - startPos).Unit
        local numChunks = math.ceil(distance / CONFIG.MAX_TELEPORT_DISTANCE)
        for i = 1, numChunks do
            if not state.isTeleporting then break end
            local chunkTarget = (i == numChunks) and targetPosition or (startPos + direction * CONFIG.MAX_TELEPORT_DISTANCE * i)
            local chunkTime = (chunkTarget - root.Position).Magnitude / CONFIG.TELEPORT_SPEED
            local tween = TweenService:Create(root, TweenInfo.new(chunkTime, Enum.EasingStyle.Linear), { CFrame = CFrame.new(chunkTarget) })
            tween:Play()
            tween.Completed:Wait()
            task.wait(0.1)
        end
    else
        local travelTime = distance / CONFIG.TELEPORT_SPEED
        local tween = TweenService:Create(root, TweenInfo.new(travelTime, Enum.EasingStyle.Linear), { CFrame = CFrame.new(targetPosition) })
        tween:Play()
        tween.Completed:Wait()
    end

    state.isTeleporting = false
    return true
end

local function teleportToNPC(npcModel)
    local rootPart = npcModel:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false, "NPC sem HumanoidRootPart" end
    local targetPos = rootPart.Position + Vector3.new(0, 2, 3)
    task.spawn(function()
        ultraSmoothTeleport(targetPos)
    end)
    return true, "Teleportando..."
end

local function getTeleportNPCList()
    local list = {}
    for _, child in ipairs(TeleportFolder:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChild("HumanoidRootPart") then
            table.insert(list, child)
        end
    end
    table.sort(list, function(a, b) return a.Name < b.Name end)
    return list
end

