		local _, delaySliderBtn, delayFill, delayLabel, delayMin, delayMax = createSlider(combatPage, "Attack Delay (single)", 0.2, 0.6, State.killAuraDelay)

		-- ... resto da GUI (movement, visual, teleport, misc) igual anterior ...

		-- Toggle functions
		ToggleFunctions.killAura = function(enabled)
			State.killAuraEnabled = enabled
			Utils.animateToggle(killAuraBg, killAuraCircle, enabled)
			if enabled then
				if State.killAuraComboMode and #State.comboSequence == 0 then
					print("[CyberHub] Combo mode active but no combo recorded. Record or load a combo.")
				elseif not State.killAuraComboMode and not State.capturedArgs then
					print("[CyberHub] Single mode active but no args. Attack manually or load saved args.")
				end
				Utils.disconnectConnection("killAura")
				State.connections.killAura = Services.RunService.Heartbeat:Connect(KillAura.loop)
			else
				Utils.disconnectConnection("killAura")
				State.comboIndex = 1
			end
		end
		killAuraToggle.MouseButton1Click:Connect(function() ToggleFunctions.killAura(not State.killAuraEnabled) end)

		-- Slider handlers
		local function handleSlider(btn, fill, label, minV, maxV, precision, callback)
			local dragging = false
			btn.MouseButton1Down:Connect(function() dragging = true end)
			Services.UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
			Services.UserInputService.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					local sliderBg = btn.Parent
					local mouseX = Services.UserInputService:GetMouseLocation().X
					local pct = math.clamp((mouseX - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
					local value = minV + pct * (maxV - minV)
					value = math.floor(value * precision) / precision
					label.Text = tostring(value)
					fill.Size = Cache.UDim2_new(pct, 0, 1, 0)
					if callback then callback(value) end
				end
			end)
		end

		handleSlider(rangeSliderBtn, rangeFill, rangeLabel, rangeMin, rangeMax, 1, function(v) State.killAuraRange = v end)
		handleSlider(delaySliderBtn, delayFill, delayLabel, delayMin, delayMax, 100, function(v) State.killAuraDelay = v end)

		-- ... finalização da GUI ...
	end

	return { build=build, getToggleFunctions=function() return ToggleFunctions end }
end)()

