local ConfigManager = (function()
	local Services = Core.Services
	local CONFIG = Core.CONFIG
	local State = Core.State
	local Http = Services.HttpService
	local folder = CONFIG.CONFIG_FOLDER

	if not isfolder(folder) then makefolder(folder) end

	local function saveConfig(name)
		local data = {
			autofarmEnabled=State.autofarmEnabled, autofarmMode=State.autofarmMode, autofarmDistance=State.autofarmDistance,
			lockOnEnabled=State.lockOnEnabled, autoAttackEnabled=State.autoAttackEnabled,
			speedEnabled=State.speedEnabled, speedValue=State.speedValue, infiniteJumpEnabled=State.infiniteJumpEnabled, noClipEnabled=State.noClipEnabled,
			espEnabled=State.espEnabled, tracersEnabled=State.tracersEnabled, healthBarsEnabled=State.healthBarsEnabled,
			playerESPEnabled=State.playerESPEnabled, fovEnabled=State.fovEnabled,
		}
		writefile(folder.."/"..name..".json", Http:JSONEncode(data))
		return true
	end

	local function loadConfig(name)
		local path = folder.."/"..name..".json"
		if not isfile(path) then return false end
		local decoded = Http:JSONDecode(readfile(path))
		if not decoded then return false end
		for k,v in pairs(decoded) do if State[k]~=nil then State[k]=v end end
		if GUI and GUI.refreshToggles then GUI.refreshToggles() end
		return true
	end

	local function listConfigs()
		local files = listfiles(folder)
		local names = {}
		for _,file in ipairs(files) do
			local name = file:match(".+/([^/]+)%.json$")
			if name then table.insert(names, name) end
		end
		table.sort(names)
		return names
	end

	local function deleteConfig(name)
		local path = folder.."/"..name..".json"
		if isfile(path) then delfile(path) return true end
		return false
	end

	local function overwriteConfig(name)
		return saveConfig(name)
	end

	local autoloadFile = folder.."/autoload.txt"
	local function setAutoload(name) writefile(autoloadFile, name) end
	local function getAutoload() return isfile(autoloadFile) and readfile(autoloadFile) or nil end
	local function loadAutoload() local name = getAutoload(); if name then loadConfig(name) end end

	return { saveConfig=saveConfig, loadConfig=loadConfig, listConfigs=listConfigs, deleteConfig=deleteConfig, overwriteConfig=overwriteConfig, setAutoload=setAutoload, getAutoload=getAutoload, loadAutoload=loadAutoload }
