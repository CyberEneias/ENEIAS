		BACK_DISTANCE         = 3.5,
		HEIGHT_OFFSET         = 2.5,
		ABOVE_HEIGHT          = 8,
		MAX_DISTANCE          = 60,
		NPC_SCAN_INTERVAL     = 0.3,
		CHAR_CACHE_UPDATE     = 0.5,
		GUI_NAME              = "CyberHub",
		TELEPORT_SPEED        = 150,
		MAX_TELEPORT_DISTANCE = 500,
		VISUAL_NPC_FOLDER     = workspace:WaitForChild("Alive"),
