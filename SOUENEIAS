			State.healthBarsEnabled = enabled
			Utils.animateToggle(hbBg, hbCircle, enabled)
			if not enabled then ESP.clearAllHealthBars() end
		end
		hbToggle.MouseButton1Click:Connect(function() ToggleFunctions.healthBars(not State.healthBarsEnabled) end)

		ToggleFunctions.playerESP = function(enabled)
			State.playerESPEnabled = enabled
			Utils.animateToggle(playerESPBg, playerESPCircle, enabled)
		end
		playerESPToggle.MouseButton1Click:Connect(function() ToggleFunctions.playerESP(not State.playerESPEnabled) end)

		ToggleFunctions.fov = function(enabled)
			State.fovEnabled = enabled
			Utils.animateToggle(fovBg, fovCircle, enabled)
			if enabled then ESP.createFOVCircle() else ESP.removeFOVCircle() end
		end
		fovToggle.MouseButton1Click:Connect(function() ToggleFunctions.fov(not State.fovEnabled) end)

		ToggleFunctions.lockOn = function(enabled)
			State.lockOnEnabled = enabled
			Utils.animateToggle(lockOnBg, lockOnCircle, enabled)
			Utils.disconnectConnection("lockOn")
			if enabled then
				State.connections.lockOn = Services.RunService.RenderStepped:Connect(Combat.lockOnLoop)
			end
		end
		lockOnToggle.MouseButton1Click:Connect(function() ToggleFunctions.lockOn(not State.lockOnEnabled) end)

		-- Ativa página inicial
		switchPage("combat")

		return { mainFrame = mainFrame, ToggleFunctions = ToggleFunctions, refreshConfigList = refreshConfigList }
	end

	return { build = build, getToggleFunctions = function() return ToggleFunctions end }
end)()

