    for _, npc in ipairs(npcs) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 32)
        btn.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
        btn.Text = "   📌 " .. npc.Name
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 11
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.BorderSizePixel = 0
        btn.AutoButtonColor = false
        btn.Parent = npcListContainer

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = btn

        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
        end)

        btn.MouseButton1Click:Connect(function()
            local success, msg = teleportToNPC(npc)
            local originalColor = btn.BackgroundColor3
            if success then
                btn.BackgroundColor3 = Color3.fromRGB(80, 200, 120)
            else
                btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            end
            task.wait(0.5)
            btn.BackgroundColor3 = originalColor
        end)
    end
end

refreshBtn.MouseButton1Click:Connect(populateNPCList)
task.spawn(function()
    task.wait(0.5)
    populateNPCList()
end)

