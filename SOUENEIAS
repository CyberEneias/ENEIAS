--// UNIVERSAL REMOTE LOGGER HUB (SEM FILTRO)

local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "UniversalLogger"
gui.Parent = CoreGui
gui.ResetOnSpawn = false
gui.DisplayOrder = 999999
gui.IgnoreGuiInset = true

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 550, 0, 320)
frame.Position = UDim2.new(0.5, -275, 0.5, -160)
frame.BackgroundColor3 = Color3.fromRGB(15,15,20)
frame.Parent = gui
frame.Active = true
frame.Draggable = true

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "UNIVERSAL REMOTE LOGGER (F2)"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = frame

local console = Instance.new("ScrollingFrame")
console.Size = UDim2.new(1,-10,1,-40)
console.Position = UDim2.new(0,5,0,35)
console.AutomaticCanvasSize = Enum.AutomaticSize.Y
console.ScrollBarThickness = 6
console.BackgroundColor3 = Color3.fromRGB(10,10,15)
console.Parent = frame

local layout = Instance.new("UIListLayout")
layout.Parent = console
layout.Padding = UDim.new(0,4)

local function addLog(text)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,-5,0,18)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(180,255,180)
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = console

    task.defer(function()
        console.CanvasPosition = Vector2.new(0, console.AbsoluteCanvasSize.Y)
    end)
end

addLog("[✔] Logger iniciado - capturando TUDO")

-- HOOK UNIVERSAL (SEM FILTRO)
local mt = getrawmetatable(game)
setreadonly(mt, false)

local old = mt.__namecall

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if method == "FireServer" or method == "InvokeServer" then
        task.spawn(function()
            addLog("🔴 REMOTE: " .. self:GetFullName())
            addLog("⚙️ Método: " .. method)

            for i, v in ipairs(args) do
                addLog("   ["..i.."] = " .. tostring(v))
            end

            addLog("────────────────────────")
        end)
    end

    return old(self, ...)
end)

-- Toggle
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F2 then
        frame.Visible = not frame.Visible
    end
end)
