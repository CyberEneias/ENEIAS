		speedEnabled       = false,
		killAuraEnabled    = false,    -- kill aura em vez de m1 macro
		attackDelay        = 0.18,     -- delay entre ataques (segundos)
		attackRange        = 12,       -- alcance do kill aura
		espEnabled         = false,
		tracersEnabled     = false,
		healthBarsEnabled  = false,
		lockOnEnabled      = false,
		noClipEnabled      = false,
		playerESPEnabled   = false,
		fovEnabled         = false,

		-- Valores
		speedValue    = 160,

		-- Referências de NPC/alvo
		lockedNPC    = nil,
		lockedTarget = nil,

		-- Timers / cache
		lastNPCScan   = 0,
		npcCache      = {},
		lastAttack    = 0,          -- para kill aura
		lastSpeedApply= 0,
		charCache     = { root=nil, humanoid=nil, character=nil, lastUpdate=0 },
		weaponCache   = nil,        -- cache do objeto Fist

		-- Conexões do RunService
		connections = {},

		-- Objetos visuais
		espObjects       = {},
