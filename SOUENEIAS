-- Cache do personagem
local charCache = { root = nil, hum = nil, lastUpdate = 0 }
local function getCharComponents()
    local now = tick()
    if now - charCache.lastUpdate > 0.3 then
        local char = LocalPlayer.Character
        charCache.root = char and char:FindFirstChild("HumanoidRootPart")
        charCache.hum = char and char:FindFirstChildOfClass("Humanoid")
        charCache.lastUpdate = now
    end
    return charCache.root, charCache.hum
end

-- Conexões ativas
local connections = {}
local function disconnect(name)
    if connections[name] then
        connections[name]:Disconnect()
        connections[name] = nil
    end
end

-- Obter NPCs válidos de Workspace.Humanoids
local function getValidNPCs()
    local npcs = {}
    local folder = CONFIG.NPC_FOLDER
    if not folder then return npcs end
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("Model") then
            local hum = child:FindFirstChildOfClass("Humanoid")
            local root = child:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 then
                table.insert(npcs, {model = child, root = root, hum = hum})
            end
        end
    end
    return npcs
end

-- NPC mais próximo
local function getClosestNPC()
    local root = getCharComponents()
    if not root then return nil end
    local closest, minDist = nil, CONFIG.MAX_DISTANCE
    for _, npc in ipairs(getValidNPCs()) do
        local dist = (root.Position - npc.root.Position).Magnitude
        if dist < minDist then
            minDist = dist
            closest = npc
        end
    end
    return closest
end

-- Speed loop
local function speedLoop()
    if not state.speedEnabled then return end
    local root, hum = getCharComponents()
    if root and hum then
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0 then
            local curY = root.AssemblyLinearVelocity.Y
            root.AssemblyLinearVelocity = (moveDir.Unit * state.speedValue) + Vector3.new(0, curY, 0)
        end
    end
end

local function setSpeed(enabled)
    state.speedEnabled = enabled
    if enabled then
        disconnect("speed")
        connections.speed = RunService.Heartbeat:Connect(speedLoop)
    else
        disconnect("speed")
    end
end

local function setInfiniteJump(enabled)
    state.infiniteJumpEnabled = enabled
end

-- Autofarm loop
local autofarmTarget = nil
local function autofarmLoop()
    if not state.autofarmEnabled then return end
    local root, hum = getCharComponents()
    if not root or not hum then return end

    if not autofarmTarget or not autofarmTarget.model.Parent then
        autofarmTarget = getClosestNPC()
    end
    if not autofarmTarget then return end

    local npcRoot = autofarmTarget.root
    local targetPos
    if state.autofarmMode == "Above" then
        targetPos = npcRoot.Position + Vector3.new(0, state.autofarmDistance, 0)
        root.CFrame = CFrame.new(targetPos) * CFrame.Angles(math.rad(-90), 0, 0)
    else
        local backVec = -npcRoot.CFrame.LookVector * state.autofarmDistance
        local upVec = Vector3.new(0, CONFIG.HEIGHT_OFFSET, 0)
        targetPos = npcRoot.Position + backVec + upVec
        root.CFrame = CFrame.new(targetPos, npcRoot.Position)
    end
    root.AssemblyLinearVelocity = Vector3.zero
end

local function setAutofarm(enabled)
    state.autofarmEnabled = enabled
    if enabled then
        disconnect("autofarm")
        connections.autofarm = RunService.Heartbeat:Connect(autofarmLoop)
    else
        disconnect("autofarm")
        autofarmTarget = nil
    end
end

-- Kill Aura com hitbox (parte ao redor do personagem)
local hitboxPart = nil
local killauraCooldown = {}

local function createHitbox()
    if hitboxPart and hitboxPart.Parent then return end
    local root = getCharComponents()
    if not root then return end
    hitboxPart = Instance.new("Part")
    hitboxPart.Name = "KillAuraHitbox"
    hitboxPart.Size = Vector3.new(state.killauraRadius * 2, state.killauraRadius * 2, state.killauraRadius * 2)
    hitboxPart.Shape = Enum.PartType.Ball
    hitboxPart.Transparency = 0.8
    hitboxPart.Color = Color3.fromRGB(255, 0, 0)
    hitboxPart.Anchored = false
    hitboxPart.CanCollide = false
    hitboxPart.Parent = root.Parent
    -- Weld à root
    local weld = Instance.new("Weld")
    weld.Part0 = root
    weld.Part1 = hitboxPart
    weld.C0 = CFrame.new(0, 0, 0)
    weld.Parent = hitboxPart
end

local function destroyHitbox()
    if hitboxPart then
        hitboxPart:Destroy()
        hitboxPart = nil
    end
end

local function killauraLoop()
    if not state.killauraEnabled then return end
    local root = getCharComponents()
    if not root then return end
    
    -- Criar/atualizar hitbox
    if not hitboxPart or not hitboxPart.Parent then
        createHitbox()
    else
        hitboxPart.Size = Vector3.new(state.killauraRadius * 2, state.killauraRadius * 2, state.killauraRadius * 2)
    end
    
    local now = tick()
    for _, npc in ipairs(getValidNPCs()) do
        if npc.hum.Health > 0 then
            local dist = (root.Position - npc.root.Position).Magnitude
            if dist <= state.killauraRadius then
                if not killauraCooldown[npc.model] or now - killauraCooldown[npc.model] >= state.killauraDelay then
                    npc.hum.Health = math.max(0, npc.hum.Health - state.killauraDamage)
                    killauraCooldown[npc.model] = now
                end
            end
        end
    end
end

local function setKillaura(enabled)
    state.killauraEnabled = enabled
    if enabled then
        createHitbox()
        disconnect("killaura")
        connections.killaura = RunService.Heartbeat:Connect(killauraLoop)
    else
        disconnect("killaura")
        destroyHitbox()
        table.clear(killauraCooldown)
    end
end

-- Instakill (mata NPC mais próximo)
local function instakill()
    local npc = getClosestNPC()
    if npc and npc.hum then
        npc.hum.Health = 0
    end
end

-- Teleporte suave
local isTeleporting = false
local function smoothTeleport(targetPos)
    if isTeleporting then return end
    local root = getCharComponents()
    if not root then return end
    isTeleporting = true
    local dist = (targetPos - root.Position).Magnitude
    local duration = math.min(dist / CONFIG.TELEPORT_SPEED, 0.5)
    TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)}):Play()
    task.wait(duration)
    isTeleporting = false
end

-- Teleportar para NPC
local function teleportToNPC(npcModel)
    local rootPart = npcModel:FindFirstChild("HumanoidRootPart")
    if rootPart then
        smoothTeleport(rootPart.Position + Vector3.new(0, 2, 0))
    end
end

-- Teleportar para região (parte)
local function teleportToRegion(regionPart)
    if regionPart:IsA("BasePart") then
        smoothTeleport(regionPart.Position + Vector3.new(0, 3, 0))
    end
end

-- ESP: Highlight
local espHighlights = {}
local function updateESP()
    for _, npc in ipairs(getValidNPCs()) do
        if state.espEnabled then
            if not espHighlights[npc.model] then
                local hl = Instance.new("Highlight")
                hl.Adornee = npc.model
                hl.FillColor = Color3.fromRGB(255, 0, 0)
                hl.FillTransparency = 0.5
                hl.OutlineColor = Color3.new(1,1,1)
                hl.Parent = npc.model
                espHighlights[npc.model] = hl
            end
        else
            if espHighlights[npc.model] then
                espHighlights[npc.model]:Destroy()
                espHighlights[npc.model] = nil
            end
        end
    end
    for model, hl in pairs(espHighlights) do
        if not model.Parent then hl:Destroy(); espHighlights[model] = nil end
    end
end

-- Tracers (Drawing lines)
local tracerLines = {}
local function updateTracers()
    if not state.tracersEnabled then
        for _, line in pairs(tracerLines) do line:Remove() end
        table.clear(tracerLines)
        return
    end
    local camera = workspace.CurrentCamera
    local screenSize = camera.ViewportSize
    local center = Vector2.new(screenSize.X/2, screenSize.Y)
    for _, npc in ipairs(getValidNPCs()) do
        local pos, onScreen = camera:WorldToViewportPoint(npc.root.Position)
        if onScreen then
            if not tracerLines[npc.model] then
                local line = Drawing.new("Line")
                line.Thickness = 2
                line.Color = Color3.new(0,1,0)
                line.Transparency = 0.7
                tracerLines[npc.model] = line
            end
            local line = tracerLines[npc.model]
            line.From = center
            line.To = Vector2.new(pos.X, pos.Y)
            line.Visible = true
        else
            if tracerLines[npc.model] then
                tracerLines[npc.model].Visible = false
            end
        end
    end
    for model, line in pairs(tracerLines) do
        if not model.Parent then line:Remove(); tracerLines[model] = nil end
    end
end

-- Health Bars (BillboardGui)
local healthBars = {}
local function updateHealthBars()
    for _, npc in ipairs(getValidNPCs()) do
        if state.healthBarsEnabled then
            if not healthBars[npc.model] then
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0, 80, 0, 20)
                bill.StudsOffset = Vector3.new(0, 3, 0)
                bill.Adornee = npc.root
                bill.AlwaysOnTop = true
                local bg = Instance.new("Frame")
                bg.Size = UDim2.new(1,0,1,0)
                bg.BackgroundColor3 = Color3.fromRGB(40,40,40)
                local bar = Instance.new("Frame")
                bar.Name = "Bar"
                bar.BackgroundColor3 = Color3.fromRGB(0,255,0)
                bar.Size = UDim2.new(npc.hum.Health/npc.hum.MaxHealth,0,1,0)
                bar.Parent = bg
                local txt = Instance.new("TextLabel")
                txt.Text = math.floor(npc.hum.Health).."/"..math.floor(npc.hum.MaxHealth)
                txt.Size = UDim2.new(1,0,1,0)
                txt.BackgroundTransparency = 1
                txt.TextColor3 = Color3.new(1,1,1)
                txt.Font = Enum.Font.GothamBold
                txt.TextScaled = true
                txt.Parent = bg
                bg.Parent = bill
                bill.Parent = npc.model
                healthBars[npc.model] = {bill=bill, bar=bar, txt=txt}
            else
                local data = healthBars[npc.model]
                local pct = npc.hum.Health / npc.hum.MaxHealth
                data.bar.Size = UDim2.new(pct,0,1,0)
                data.txt.Text = math.floor(npc.hum.Health).."/"..math.floor(npc.hum.MaxHealth)
                if pct > 0.5 then data.bar.BackgroundColor3 = Color3.fromRGB(0,255,0)
                elseif pct > 0.25 then data.bar.BackgroundColor3 = Color3.fromRGB(255,255,0)
                else data.bar.BackgroundColor3 = Color3.fromRGB(255,0,0) end
            end
        else
            if healthBars[npc.model] then
                healthBars[npc.model].bill:Destroy()
                healthBars[npc.model] = nil
            end
        end
    end
end

