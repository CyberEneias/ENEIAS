local function refreshRegions()
    for _, child in pairs(regionScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local regionsFolder = workspace:FindFirstChild("Regions")
    if not regionsFolder then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 30)
        empty.BackgroundTransparency = 1
        empty.Text = "No 'Regions' folder found in workspace"
        empty.TextColor3 = Color3.fromRGB(120, 120, 140)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.Parent = regionScroll
        return
    end
    
    local regions = {}
    for _, obj in ipairs(regionsFolder:GetChildren()) do
        local pos = nil
        if obj:IsA("BasePart") then
            pos = obj.Position
        elseif obj:IsA("Model") then
            local prim = obj.PrimaryPart
            if prim then pos = prim.Position end
        end
        if pos then
            table.insert(regions, {name = obj.Name, position = pos, obj = obj})
        end
    end
    
    if #regions == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 30)
        empty.BackgroundTransparency = 1
        empty.Text = "No regions (parts/models) inside Regions folder"
        empty.TextColor3 = Color3.fromRGB(120, 120, 140)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.Parent = regionScroll
        return
    end
    
    for _, reg in ipairs(regions) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 28)
        btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        btn.Text = "📍 " .. reg.name
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 11
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Parent = regionScroll
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            local pos = reg.position
            if pos then
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                end
            end
        end)
    end
end

