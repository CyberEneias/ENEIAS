--//====================================================--
--//                 NPC CACHE SYSTEM                   --
--//====================================================--

local NPCCache = (function()
	local State    = Core.State
	local CONFIG   = Core.CONFIG
	local Services = Core.Services
	local player   = Services.Players.LocalPlayer

	local function updateCache()
		table.clear(State.npcCache)
		local root = Utils.getCharComponents()
		if not root then return end

		for _, npc in ipairs(CONFIG.VISUAL_NPC_FOLDER:GetChildren()) do
			if npc:IsA("Model") and npc ~= player.Character then
				local hum     = npc:FindFirstChild("Humanoid")
				local npcRoot = npc:FindFirstChild("HumanoidRootPart")
				if hum and npcRoot and hum.Health > 0 then
					local dist = (root.Position - npcRoot.Position).Magnitude
					if dist <= CONFIG.MAX_DISTANCE then
						table.insert(State.npcCache, {
							model    = npc,
							root     = npcRoot,
							humanoid = hum,
							distance = dist,
						})
					end
				end
			end
		end

		table.sort(State.npcCache, function(a, b) return a.distance < b.distance end)
	end

	local function findClosest()
		local now = tick()
		if now - State.lastNPCScan > CONFIG.NPC_SCAN_INTERVAL then
			updateCache()
			State.lastNPCScan = now
		end
		return State.npcCache[1] and State.npcCache[1].model
	end

	local function getAllWithin(range)
		local now = tick()
		if now - State.lastNPCScan > CONFIG.NPC_SCAN_INTERVAL then
			updateCache()
			State.lastNPCScan = now
		end
		local result = {}
		for _, data in ipairs(State.npcCache) do
			if data.distance <= range then
				table.insert(result, data)
			end
		end
		return result
	end

	local function isValid(npc)
		if not npc or not npc.Parent then return false end
		local hum     = npc:FindFirstChild("Humanoid")
		local npcRoot = npc:FindFirstChild("HumanoidRootPart")
		if not hum or not npcRoot or hum.Health <= 0 then return false end

		local root = Utils.getCharComponents()
		if not root then return false end

		return (root.Position - npcRoot.Position).Magnitude <= Core.CONFIG.MAX_DISTANCE
	end

	return {
		update       = updateCache,
		findClosest  = findClosest,
		getAllWithin = getAllWithin,
		isValid      = isValid,
	}
end)()

--//====================================================--
--//            KILL AURA (PERSISTENT + COMBO)          --
--//====================================================--

local KillAura = (function()
	local State    = Core.State
	local Services = Core.Services
	local Cache    = Core.Cache
	local CONFIG   = Core.CONFIG

	-- ========== Serialização / Desserialização ==========
	local function serializeArg(arg)
		local t = typeof(arg)
		if t == "number" or t == "string" or t == "boolean" then
			return arg
		elseif t == "CFrame" then
			local x, y, z, R00, R01, R02, R10, R11, R12, R20, R21, R22 = arg:GetComponents()
			return { __type = "CFrame", x=x, y=y, z=z, R00=R00, R01=R01, R02=R02, R10=R10, R11=R11, R12=R12, R20=R20, R21=R21, R22=R22 }
		elseif t == "Instance" then
			local path = ""
			local success, result = pcall(function() return arg:GetFullName() end)
			if success and result then path = result else path = arg.Name or "Unknown" end
			return { __type = "Instance", path = path }
		else
			return { __type = "unknown", value = tostring(arg) }
		end
	end

	local function deserializeArg(data)
		if type(data) ~= "table" then return data end
		if data.__type == "CFrame" then
			return CFrame.new(
				data.x, data.y, data.z,
				data.R00, data.R01, data.R02,
				data.R10, data.R11, data.R12,
				data.R20, data.R21, data.R22
			)
		elseif data.__type == "Instance" then
			local function getInstanceFromPath(path)
				local parts = {}
				for part in string.gmatch(path, "[^%.]+") do
					table.insert(parts, part)
				end
				local current = game
				for _, part in ipairs(parts) do
					if current:FindFirstChild(part) then
						current = current[part]
					else
						return nil
					end
				end
				return current
			end
			local inst = getInstanceFromPath(data.path)
			if inst then return inst end
			return nil
		else
			return data.value
		end
	end

	-- ========== Ataque único (args) ==========
	local function saveSingleArgs()
		if not State.capturedArgs then return false end
		local serialized = {}
		for i, arg in ipairs(State.capturedArgs) do
			serialized[i] = serializeArg(arg)
		end
		local json = Services.HttpService:JSONEncode(serialized)
		local success, err = pcall(function() writefile(CONFIG.ARGS_FILE, json) end)
		if success then print("[CyberHub] Single args saved.") else warn("[CyberHub] Save failed: "..tostring(err)) end
		return success
	end

	local function loadSingleArgs()
		local success, data = pcall(function() return readfile(CONFIG.ARGS_FILE) end)
		if not success or not data then return false end
		local decoded = Services.HttpService:JSONDecode(data)
		if type(decoded) ~= "table" then return false end
		local args = {}
		for i, ser in ipairs(decoded) do
			args[i] = deserializeArg(ser)
		end
		State.capturedArgs = args
		print("[CyberHub] Single args loaded.")
		return true
	end

	-- ========== Combo (sequência) ==========
	local function saveCombo()
		if #State.comboSequence == 0 then return false end
		local serialized = {}
		for idx, step in ipairs(State.comboSequence) do
			local stepSer = { delay = step.delay, args = {} }
			for i, arg in ipairs(step.args) do
				stepSer.args[i] = serializeArg(arg)
			end
			serialized[idx] = stepSer
		end
		local json = Services.HttpService:JSONEncode(serialized)
		local success, err = pcall(function() writefile(CONFIG.COMBO_FILE, json) end)
		if success then print("[CyberHub] Combo saved ("..#State.comboSequence.." hits).") else warn("[CyberHub] Combo save failed: "..tostring(err)) end
		return success
	end

	local function loadCombo()
		local success, data = pcall(function() return readfile(CONFIG.COMBO_FILE) end)
		if not success or not data then return false end
		local decoded = Services.HttpService:JSONDecode(data)
		if type(decoded) ~= "table" then return false end
		local combo = {}
		for _, stepSer in ipairs(decoded) do
			local step = { delay = stepSer.delay, args = {} }
			for i, ser in ipairs(stepSer.args) do
				step.args[i] = deserializeArg(ser)
				if step.args[i] == nil and ser.__type == "Instance" then
					warn("[CyberHub] Failed to restore instance in combo:", ser.path)
					return false
				end
			end
			table.insert(combo, step)
		end
		State.comboSequence = combo
		print("[CyberHub] Combo loaded ("..#combo.." hits).")
		return true
	end

	local function resetCombo()
		State.comboSequence = {}
		pcall(function() deletefile(CONFIG.COMBO_FILE) end)
		print("[CyberHub] Combo reset.")
	end

	-- ========== Gravação de combo ==========
	local function startRecording()
		if State.isRecording then return end
		State.comboSequence = {}
		State.isRecording = true
		State.recordingStart = tick()
		State.lastAttackTime = State.recordingStart
		print("[CyberHub] Recording combo started. Perform your combo now.")
		-- Timer automático: para gravação após CONFIG.COMBO_TIMEOUT segundos sem ataque
		if State.recordingTimer then State.recordingTimer:Disconnect() end
		State.recordingTimer = Services.RunService.Heartbeat:Connect(function()
			if not State.isRecording then
				if State.recordingTimer then State.recordingTimer:Disconnect() end
				return
			end
			if tick() - State.lastAttackTime > CONFIG.COMBO_TIMEOUT then
				stopRecording()
			end
		end)
	end

	local function stopRecording()
		if not State.isRecording then return end
		State.isRecording = false
		if State.recordingTimer then State.recordingTimer:Disconnect(); State.recordingTimer = nil end
		print(string.format("[CyberHub] Recording stopped. %d hits recorded.", #State.comboSequence))
		if #State.comboSequence > 0 then
			saveCombo()
		end
	end

	-- Hook para capturar ataques (tanto para single args quanto para combo)
	local function captureArgsHook()
		local remote = State.combatRemote
		if not remote then return end
		local mt = getrawmetatable(game)
		if not mt then return end
		local oldNamecall = mt.__namecall
		setreadonly(mt, false)

		mt.__namecall = newcclosure(function(self, ...)
			local args = {...}
			local method = getnamecallmethod()
			if self == remote and method == "FireServer" then
				-- Salva o ataque único (sempre o último)
				State.capturedArgs = args
				task.spawn(saveSingleArgs)

				-- Se estiver gravando combo, adiciona à sequência
				if State.isRecording then
					local now = tick()
					local relativeDelay = now - State.lastAttackTime
					State.lastAttackTime = now
					table.insert(State.comboSequence, {
						args = args,
						delay = relativeDelay
					})
				end
			end
			return oldNamecall(self, ...)
		end)
	end

	-- ========== Execução de ataques ==========
	local function getAttackCFrame(npcRoot)
		local root = Utils.getCharComponents()
		if not root then return nil end
		return Cache.CFrame_new(root.Position, npcRoot.Position)
	end

	local function executeAttack(args, npc)
		local npcRoot = npc:FindFirstChild("HumanoidRootPart")
		if not npcRoot then return false end
		local argsCopy = {}
		for i, v in ipairs(args) do
			argsCopy[i] = v
		end
		if argsCopy[3] then
			argsCopy[3] = getAttackCFrame(npcRoot)
		end
		pcall(function()
			State.combatRemote:FireServer(unpack(argsCopy))
		end)
		return true
	end

	-- Loop do Kill Aura (single attack)
	local function killAuraSingleLoop()
		if not State.killAuraEnabled then return end
		if not State.capturedArgs then return end

		local now = tick()
		if now - State.lastAttack < State.killAuraDelay then return end

		local root = Utils.getCharComponents()
		if not root then return end

		local targetNPC = nil
		if State.killAuraMode == "Closest" then
			local closest = NPCCache.findClosest()
			if closest and NPCCache.isValid(closest) then
				local npcRoot = closest:FindFirstChild("HumanoidRootPart")
				if npcRoot and (root.Position - npcRoot.Position).Magnitude <= State.killAuraRange then
					targetNPC = closest
				end
			end
		else -- All
			local npcs = NPCCache.getAllWithin(State.killAuraRange)
			for _, data in ipairs(npcs) do
				executeAttack(State.capturedArgs, data.model)
				State.lastAttack = now
				task.wait(0.05)
			end
			return
		end

		if targetNPC then
			executeAttack(State.capturedArgs, targetNPC)
			State.lastAttack = now
		end
	end

	-- Loop do Kill Aura (combo)
	local function killAuraComboLoop()
		if not State.killAuraEnabled then return end
		if #State.comboSequence == 0 then return end

		local now = tick()
		if State.comboIndex == 1 then
			-- início do combo
			State.comboLastTime = now
		else
			local step = State.comboSequence[State.comboIndex]
			if now - State.comboLastTime < step.delay then return end
		end

		local root = Utils.getCharComponents()
		if not root then return end

		local step = State.comboSequence[State.comboIndex]
		local targets = {}
		if State.killAuraMode == "Closest" then
			local closest = NPCCache.findClosest()
			if closest and NPCCache.isValid(closest) then
				local npcRoot = closest:FindFirstChild("HumanoidRootPart")
				if npcRoot and (root.Position - npcRoot.Position).Magnitude <= State.killAuraRange then
					targets = {closest}
				end
			end
		else -- All
			local npcs = NPCCache.getAllWithin(State.killAuraRange)
			for _, data in ipairs(npcs) do
				table.insert(targets, data.model)
			end
		end

		for _, npc in ipairs(targets) do
			executeAttack(step.args, npc)
		end

		State.comboLastTime = now
		State.comboIndex = State.comboIndex + 1
		if State.comboIndex > #State.comboSequence then
			State.comboIndex = 1  -- loop infinito
		end
	end

	local function killAuraMainLoop()
		if State.killAuraComboMode then
			killAuraComboLoop()
		else
			killAuraSingleLoop()
		end
	end

	return {
		captureArgsHook = captureArgsHook,
		saveSingleArgs  = saveSingleArgs,
		loadSingleArgs  = loadSingleArgs,
		loadCombo       = loadCombo,
		saveCombo       = saveCombo,
		resetCombo      = resetCombo,
		startRecording  = startRecording,
		stopRecording   = stopRecording,
		loop            = killAuraMainLoop,
		isRecording     = function() return State.isRecording end,
	}
end)()

