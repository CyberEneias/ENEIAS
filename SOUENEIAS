		BACK_DISTANCE         = 3.5,
		HEIGHT_OFFSET         = 2.5,
		ABOVE_HEIGHT          = 8,
		MAX_DISTANCE          = 60,
		NPC_SCAN_INTERVAL     = 0.3,
