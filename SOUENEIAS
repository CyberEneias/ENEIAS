local ConfigManager = (function()
	local Services = Core.Services
	local CONFIG   = Core.CONFIG
	local State    = Core.State
	local Http     = Services.HttpService
	local folder   = CONFIG.CONFIG_FOLDER

	-- Cria pasta se não existir
	if not isfolder(folder) then
		makefolder(folder)
	end

	-- Salva o estado atual em um arquivo JSON
	local function saveConfig(name)
		local data = {
			-- combat
			autofarmEnabled    = State.autofarmEnabled,
			autofarmMode       = State.autofarmMode,
			autofarmDistance   = State.autofarmDistance,
			lockOnEnabled      = State.lockOnEnabled,
			killAuraEnabled    = State.killAuraEnabled,
			attackDelay        = State.attackDelay,
			attackRange        = State.attackRange,
			-- movement
			speedEnabled       = State.speedEnabled,
			speedValue         = State.speedValue,
			infiniteJumpEnabled= State.infiniteJumpEnabled,
			noClipEnabled      = State.noClipEnabled,
			-- visuals
			espEnabled         = State.espEnabled,
			tracersEnabled     = State.tracersEnabled,
			healthBarsEnabled  = State.healthBarsEnabled,
			playerESPEnabled   = State.playerESPEnabled,
			fovEnabled         = State.fovEnabled,
		}
		local path = folder .. "/" .. name .. ".json"
		writefile(path, Http:JSONEncode(data))
		return true
	end

	-- Carrega configuração de um arquivo
	local function loadConfig(name)
		local path = folder .. "/" .. name .. ".json"
		if not isfile(path) then return false end
		local decoded = Http:JSONDecode(readfile(path))
		if not decoded then return false end

		-- Aplica os valores ao estado
		for k, v in pairs(decoded) do
			if State[k] ~= nil then
				State[k] = v
			end
		end

		-- Atualiza toggles da GUI (se já existir)
		if GUI and GUI.refreshToggles then
			GUI.refreshToggles()
		end

		return true
	end

	-- Lista todas as configurações salvas
	local function listConfigs()
		local files = listfiles(folder)
		local names = {}
		for _, file in ipairs(files) do
			local name = file:match(".+/([^/]+)%.json$")
			if name then
				table.insert(names, name)
			end
		end
		table.sort(names)
		return names
	end

	-- Deleta uma configuração
	local function deleteConfig(name)
		local path = folder .. "/" .. name .. ".json"
		if isfile(path) then
			delfile(path)
			return true
		end
		return false
	end

	-- Autoload
	local autoloadFile = folder .. "/autoload.txt"
	local function setAutoload(name)
		writefile(autoloadFile, name)
	end

	local function getAutoload()
		if isfile(autoloadFile) then
			return readfile(autoloadFile)
		end
		return nil
	end

	local function loadAutoload()
		local name = getAutoload()
		if name then
			loadConfig(name)
		end
	end

	return {
		saveConfig   = saveConfig,
		loadConfig   = loadConfig,
		listConfigs  = listConfigs,
		deleteConfig = deleteConfig,
		setAutoload  = setAutoload,
		getAutoload  = getAutoload,
		loadAutoload = loadAutoload,
	}
end)()

