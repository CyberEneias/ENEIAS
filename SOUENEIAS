UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end

    -- F1: toggle GUI visibility
    if input.KeyCode == Enum.KeyCode.F1 then
        state.guiVisible = not state.guiVisible
        mainFrame.Visible = state.guiVisible
    end

    -- Keypad 1: toggle Speed
    if input.KeyCode == Enum.KeyCode.KeypadOne then
        local newState = not state.speedEnabled
        setSpeed(newState)
        -- Atualiza visual do toggle se a GUI estiver visível (opcional)
        -- Como o toggle não tem referência direta, apenas funcionalidade
    end

    -- Keypad 2: toggle Infinite Jump
    if input.KeyCode == Enum.KeyCode.KeypadTwo then
        local newState = not state.infiniteJumpEnabled
        setInfiniteJump(newState)
    end
end)

