}

-- Cache do personagem
local charCache = { root = nil, hum = nil, lastUpdate = 0 }
local function getCharComponents()
    local now = tick()
    if now - charCache.lastUpdate > 0.3 then
        local char = LocalPlayer.Character
        charCache.root = char and char:FindFirstChild("HumanoidRootPart")
        charCache.hum = char and char:FindFirstChildOfClass("Humanoid")
        charCache.lastUpdate = now
    end
    return charCache.root, charCache.hum
end

-- Conexões ativas
local connections = {}

local function disconnect(name)
    if connections[name] then
        connections[name]:Disconnect()
        connections[name] = nil
    end
end

-- Speed loop
local function speedLoop()
    if not state.speedEnabled then return end
    local root, hum = getCharComponents()
    if root and hum then
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0 then
            local curY = root.AssemblyLinearVelocity.Y
            root.AssemblyLinearVelocity = (moveDir.Unit * state.speedValue) + Vector3.new(0, curY, 0)
        end
    end
end

local function setSpeed(enabled)
    state.speedEnabled = enabled
    if enabled then
        disconnect("speed")
        connections.speed = RunService.Heartbeat:Connect(speedLoop)
    else
        disconnect("speed")
    end
    if updateSpeedToggle then updateSpeedToggle(enabled) end
end

local function setInfiniteJump(enabled)
    state.infiniteJumpEnabled = enabled
    if updateJumpToggle then updateJumpToggle(enabled) end
end

-- ========== INSTAKILL OTIMIZADO (TOGGLE + LOOP + CACHE) ==========
local npcCache = { list = {}, lastUpdate = 0 }
local instakillConnection = nil

-- Atualiza cache de NPCs a cada 1 segundo (otimização)
local function updateNPCCache()
    local now = tick()
    if now - npcCache.lastUpdate < 1 then return end
    npcCache.lastUpdate = now
    
    local newList = {}
    local playerChar = LocalPlayer.Character
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Parent ~= playerChar and obj.Health > 0 then
            local rootPart = obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent:FindFirstChild("Torso") or obj.Parent:FindFirstChild("UpperTorso")
            if rootPart then
                table.insert(newList, {
                    humanoid = obj,
                    rootPart = rootPart,
                })
            end
        end
    end
    npcCache.list = newList
end

-- Mata o NPC mais próximo do jogador dentro do raio
local function killClosestNPC()
    if not state.instakillEnabled then return end
    
    local playerRoot = getCharComponents()
    if not playerRoot then return end
    
    updateNPCCache() -- atualiza cache periodicamente
    
    local closestDist = state.instakillRadius + 1
    local closestNPC = nil
    
    for _, npc in ipairs(npcCache.list) do
        if npc.humanoid and npc.humanoid.Parent and npc.humanoid.Health > 0 then
            local dist = (npc.rootPart.Position - playerRoot.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestNPC = npc
            end
        end
    end
    
    if closestNPC then
        -- Método robusto para matar o NPC
        local hum = closestNPC.humanoid
        pcall(function()
            hum.Health = 0
            hum:BreakJoints()
            -- Remove o modelo inteiro se necessário
            if hum.Parent then
                hum.Parent:BreakJoints()
            end
        end)
        -- Pequeno delay entre mortes (se configurado)
        task.wait(state.instakillDelay)
    end
end

-- Inicia/para o loop do instakill
local function setInstakill(enabled)
    state.instakillEnabled = enabled
    if enabled then
        if not instakillConnection then
            instakillConnection = RunService.Heartbeat:Connect(function()
                killClosestNPC()
            end)
        end
    else
        if instakillConnection then
            instakillConnection:Disconnect()
            instakillConnection = nil
        end
    end
    if updateInstakillToggle then updateInstakillToggle(enabled) end
end

