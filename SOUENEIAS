--// SIMPLE REMOTE LOGGER HUB UI

local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "RemoteLoggerHub"
gui.Parent = CoreGui

gui.ResetOnSpawn = false

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 500, 0, 300)
frame.Position = UDim2.new(0.5, -250, 0.5, -150)
frame.BackgroundColor3 = Color3.fromRGB(15,15,20)
frame.Parent = gui
frame.Active = true
frame.Draggable = true

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "Remote Logger Hub"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = frame

local console = Instance.new("ScrollingFrame")
console.Size = UDim2.new(1,-10,1,-40)
console.Position = UDim2.new(0,5,0,35)
console.CanvasSize = UDim2.new(0,0,0,0)
console.AutomaticCanvasSize = Enum.AutomaticSize.Y
console.ScrollBarThickness = 4
console.BackgroundColor3 = Color3.fromRGB(10,10,15)
console.Parent = frame

local layout = Instance.new("UIListLayout")
layout.Parent = console
layout.Padding = UDim.new(0,4)

local function addLog(text)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,-5,0,20)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(180,180,255)
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = console
end

-- HOOK
local mt = getrawmetatable(game)
setreadonly(mt,false)

local old = mt.__namecall

mt.__namecall = newcclosure(function(self,...)
    local args = {...}
    local method = getnamecallmethod()

    if method == "FireServer" then
        addLog("REMOTE: "..self:GetFullName())

        for i,v in ipairs(args) do
            addLog("  ["..i.."] = "..tostring(v))
        end

        addLog("---------------------------")
    end

    return old(self,...)
end)

-- Toggle key
local UserInputService = game:GetService("UserInputService")

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F2 then
        frame.Visible = not frame.Visible
    end
end)
