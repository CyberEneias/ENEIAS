                btn.Parent = regionScroll
                local btnCorner = Instance.new("UICorner")
                btnCorner.CornerRadius = UDim.new(0, 4)
                btnCorner.Parent = btn
                btn.MouseButton1Click:Connect(function()
                    if reg.position then
                        local char = LocalPlayer.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            char.HumanoidRootPart.CFrame = CFrame.new(reg.position + Vector3.new(0, 3, 0))
                        end
                    end
                end)
            end
        end
        refreshRegionList()
        
    elseif tabName == "💀 Instakill" then
        local instaContainer, iUp = createToggle(scrollContent, "Instakill", "Kill nearest NPC continuously (Keypad 3 toggle)", state.instakillEnabled, setInstakill)
        updateInstakillToggle = iUp
        local delaySlider = createSlider(scrollContent, "Kill Delay (seconds)", 0.05, 2, state.instakillDelay, function(val)
            state.instakillDelay = val
        end)
        local radiusSlider = createSlider(scrollContent, "Hitbox Radius (studs)", 5, 100, state.instakillRadius, function(val)
            state.instakillRadius = val
        end)
        local infoLabel = Instance.new("TextLabel")
        infoLabel.Size = UDim2.new(1, -10, 0, 30)
        infoLabel.BackgroundTransparency = 1
        infoLabel.Text = "⚡ Press Keypad 3 to toggle ON/OFF\n💀 While ON, kills the closest NPC within radius every tick"
        infoLabel.Font = Enum.Font.Gotham
        infoLabel.TextSize = 10
        infoLabel.TextColor3 = Color3.fromRGB(100, 180, 255)
        infoLabel.TextWrapped = true
        infoLabel.Parent = scrollContent
    end
end

