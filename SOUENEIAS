UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F1 then
        state.guiVisible = not state.guiVisible
        mainFrame.Visible = state.guiVisible
    elseif input.KeyCode == Enum.KeyCode.F2 then
        local newState = not state.m1MacroEnabled
        state.m1MacroEnabled = newState
        if newState then
            disconnect("m1macro")
            connections.m1macro = RunService.Heartbeat:Connect(m1MacroLoop)
        else
            disconnect("m1macro")
        end
    elseif input.KeyCode == Enum.KeyCode.F3 then
        local newState = not state.autofarmEnabled
        state.autofarmEnabled = newState
        if newState then
            disconnect("autofarm")
            connections.autofarm = RunService.Heartbeat:Connect(autofarmLoop)
            lockedNPC = nil
        else
            disconnect("autofarm")
            lockedNPC = nil
        end
    elseif input.KeyCode == Enum.KeyCode.KeypadOne then
        setSpeed(not state.speedEnabled)
    elseif input.KeyCode == Enum.KeyCode.KeypadTwo then
        setInfiniteJump(not state.infiniteJumpEnabled)
    elseif input.KeyCode == Enum.KeyCode.KeypadThree then
        local newState = not state.lockOnEnabled
        state.lockOnEnabled = newState
        if newState then
            disconnect("lockOn")
            connections.lockOn = RunService.RenderStepped:Connect(lockOnLoop)
        else
            disconnect("lockOn")
            lockedTarget = nil
        end
    end
end)

