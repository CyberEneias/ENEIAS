local function refreshNPCs()
    for _, child in pairs(npcScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local npcs = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Parent ~= LocalPlayer.Character then
            local rootPart = obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent:FindFirstChild("Torso") or obj.Parent:FindFirstChild("UpperTorso")
            if rootPart then
                table.insert(npcs, {name = obj.Parent.Name, root = rootPart})
            end
        end
    end
    
    if #npcs == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 30)
        empty.BackgroundTransparency = 1
        empty.Text = "No NPCs found"
        empty.TextColor3 = Color3.fromRGB(120, 120, 140)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.Parent = npcScroll
        return
    end
    
    for _, npc in ipairs(npcs) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 28)
        btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        btn.Text = "📍 " .. npc.name
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 11
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Parent = npcScroll
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            local rootPart = npc.root
            if rootPart and rootPart.Parent then
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = rootPart.CFrame + Vector3.new(0, 3, 0)
                end
            else
                btn.Text = "⚠️ " .. npc.name .. " (unavailable)"
                task.wait(1)
                btn.Text = "📍 " .. npc.name
            end
        end)
    end
end

