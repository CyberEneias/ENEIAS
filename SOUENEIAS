local function populateTeleportList()
    for _, child in ipairs(npcListContainer:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    local npcs = getTeleportNPCList()
    if #npcs == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 40)
        empty.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
        empty.Text = "   Nenhum NPC encontrado em Workspace.NPCS.Dialog"
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.TextColor3 = Color3.fromRGB(150, 150, 170)
        empty.TextXAlignment = Enum.TextXAlignment.Left
        empty.Parent = npcListContainer
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, 6)
        c.Parent = empty
        return
    end
    for _, npc in ipairs(npcs) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 32)
        btn.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
        btn.Text = "   📌 " .. npc.Name
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 11
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.BorderSizePixel = 0
        btn.AutoButtonColor = false
        btn.Parent = npcListContainer
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, 6)
        c.Parent = btn
        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
        end)
        btn.MouseButton1Click:Connect(function()
            local success = teleportToNPC(npc)
            local original = btn.BackgroundColor3
            btn.BackgroundColor3 = success and Color3.fromRGB(80, 200, 120) or Color3.fromRGB(200, 50, 50)
            task.wait(0.5)
            btn.BackgroundColor3 = original
        end)
    end
end

refreshBtn.MouseButton1Click:Connect(populateTeleportList)
